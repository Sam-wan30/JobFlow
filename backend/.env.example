# Database
# For local development: DATABASE_URL="postgresql://user:password@localhost:5432/jobflow?schema=public"
# For Render: Will be automatically set by render.yaml
DATABASE_URL="postgresql://user:password@localhost:5432/jobflow?schema=public"

# JWT Secrets
# IMPORTANT: Change these in production! Render will auto-generate secure values.
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Server Configuration
PORT=5001
NODE_ENV=development

# Frontend URL
# For local development: FRONTEND_URL="http://localhost:5173"
# For Render: Will be automatically set by render.yaml to point to frontend service
FRONTEND_URL="http://localhost:5173"

# Google OAuth
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# For Render: Will be automatically set by render.yaml
GOOGLE_CALLBACK_URL="http://localhost:5001/api/auth/google/callback"

# Email Service (for welcome emails)
# For Gmail: Use App Password from Google Account settings
EMAIL_SERVICE="gmail"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-specific-password"
EMAIL_FROM="JobFlow <noreply@jobflow.com>"

